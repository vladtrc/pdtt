package web

import "strconv"

const defaultScenePlaceholder = `scene shape_morph

path s:
  at: [0, 0]
  points: rect{w: 2, h: 2}
  closed: 1
  stroke.color: color.white
  stroke.width: 0.04

| 1s | in:draw | s
`

templ IndexPage(llmDocs string) {
	<!DOCTYPE html>
	<html lang="en" data-theme="dark">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>pdtt playground</title>
			<link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css"/>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			<script src="https://unpkg.com/htmx.org@4.0.0-beta4/dist/htmx.min.js"></script>
			<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
			<style>
				[x-cloak] {
					display: none !important;
				}
				/* CodeJar editor: a contenteditable div with the browser's own caret
				   (no transparent-textarea overlay, so the caret can't drift). */
				#scene-editor {
					font: 0.875rem/1.5 ui-monospace, SFMono-Regular, Menlo, monospace;
					tab-size: 2;
					white-space: pre-wrap;
					word-break: break-word;
					overflow-wrap: break-word;
					padding: 0.75rem;
					overflow: auto;
					outline: none;
					color: #c9d1d9;
				}
				.c-comment { color: #6a737d; font-style: italic; }
				.c-str     { color: #a5d6ff; }
				.c-kw      { color: #ff7b72; font-weight: 600; }
				.c-const   { color: #79c0ff; }
				.c-op      { color: #d2a8ff; }
				.c-pipe    { color: #ffa657; }
				.c-num     { color: #f2cc60; }
			</style>
			<script>
				window.pdttGenerateBusy = () => {
					const data = document.body?._x_dataStack?.[0];
					return data?.aiBusy === true;
				};

				window.pdttCopyFrom = window.pdttCopyFrom || function(button, name) {
					const source = button.closest("[data-copy-card]")?.querySelector('[data-copy-source="' + name + '"]');
					const text = source?.textContent || "";
					const done = () => {
						const previous = button.textContent;
						button.textContent = "copied";
						setTimeout(() => { button.textContent = previous; }, 1200);
					};
					if (navigator.clipboard?.writeText) {
						navigator.clipboard.writeText(text).then(done);
						return;
					}
					const textarea = document.createElement("textarea");
					textarea.value = text;
					textarea.style.position = "fixed";
					textarea.style.left = "-9999px";
					document.body.appendChild(textarea);
					textarea.focus();
					textarea.select();
					document.execCommand("copy");
					textarea.remove();
					done();
				};

				// pdtt syntax highlighter used by the CodeJar editor: one master regex
				// consumes the text once so gaps between tokens are HTML-escaped exactly
				// once. ponytail: covers the tokens that matter (comments, strings,
				// scene kw, namespaced constants, ->, |, numbers); rest is plain text.
				(() => {
					const TOKEN = /(#[^\n]*)|("(?:[^"\\]|\\.)*")|\b(scene)\b|\b((?:color|corner|approx|math)\.[a-z_]+)\b|(->)|(\|)|(-?\d+(?:\.\d+)?)/g;
					const CLASS = [null, "c-comment", "c-str", "c-kw", "c-const", "c-op", "c-pipe", "c-num"];
					const esc = (s) => s.replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c]));
					function highlight(src) {
						let out = "", last = 0, m;
						TOKEN.lastIndex = 0;
						while ((m = TOKEN.exec(src))) {
							out += esc(src.slice(last, m.index));
							let gi = 1;
							while (gi < m.length && m[gi] === undefined) gi++;
							out += '<span class="' + CLASS[gi] + '">' + esc(m[0]) + "</span>";
							last = m.index + m[0].length;
						}
						return out + esc(src.slice(last));
					}
					window.pdttHighlightEl = (el) => { el.innerHTML = highlight(el.textContent); };
				})();

				document.addEventListener("alpine:init", () => {
					Alpine.data("renderPage", () => ({
						busy: false,
						aiBusy: false,
						lastRenderFailed: false,
						settled: false,
						generateStage: "",
						generateDetail: "",
						generateStartedAt: null,
						generateElapsedSeconds: 0,
						generateTimer: null,
						freePromptOpen: false,
						pipelineTitle: "Ready",
						pipelineDetail: "Edit the scene or generate PDTT — it renders automatically.",

						requestElement(event) {
							return event.detail?.ctx?.sourceElement || event.detail?.ctx?.request?.elt || event.detail?.elt || event.target;
						},

						responseStatus(event) {
							return event.detail?.ctx?.response?.status || event.detail?.xhr?.status || 0;
						},

						// The single signal the user reads: does the preview on the right
						// match the scene on the left? compiling → in flight; error → last
						// render failed; synced → output reflects the current scene.
						syncState() {
							if (!this.settled || this.busy) return "compiling";
							return this.lastRenderFailed ? "error" : "synced";
						},

						beforeRequest(event) {
							const element = this.requestElement(event);
							if (element?.id === "render-form") {
								this.busy = true;
								this.pipelineTitle = "Compiling your scene…";
								this.pipelineDetail = "Rendering the preview from the text on the left.";
							}
							if (element?.id === "generate-form") {
								this.aiBusy = true;
								this.generateStage = "sending prompt";
								this.generateDetail = "Opening external LLM request.";
								this.startGenerateTimer();
								this.pipelineTitle = "AI: sending prompt";
								this.pipelineDetail = this.generateDetail;
							}
						},

						beforeSwap(event) {
							if (this.responseStatus(event) >= 400 && "shouldSwap" in event.detail) {
								event.detail.shouldSwap = true;
							}
						},

						afterRequest(event) {
							const element = this.requestElement(event);
							const status = this.responseStatus(event);
							const failed = status >= 400;
							if (element?.id === "render-form") {
								this.busy = false;
								// 0 = aborted/replaced, 409 = server busy → the convergence
								// guard retries; neither is a final answer for the scene.
								if (status !== 0 && status !== 409) {
									this.settled = true;
									this.lastRenderFailed = failed;
								}
								this.pipelineTitle = failed ? "Compilation failed" : "Preview updated";
								this.pipelineDetail = failed ? "See the error on the right; copy it into Claude to fix." : "The preview now matches your scene.";
							}
							if (element?.id === "generate-form") {
								this.aiBusy = false;
								this.stopGenerateTimer();
								if (failed) {
									this.pipelineTitle = "AI generation failed";
									this.pipelineDetail = "The AI request returned an error. Details are shown below the prompt.";
								} else if (!this.busy) {
									this.pipelineTitle = "AI generated pdtt";
									this.pipelineDetail = "The scene was inserted into the editor and is rendering automatically.";
								}
							}
						},

						updateGenerationStatus(event) {
							if (!event.detail.running) return;
							this.generateStage = event.detail.stage;
							this.generateDetail = event.detail.detail;
							if (this.aiBusy) {
								this.pipelineTitle = "AI: " + event.detail.stage;
								this.pipelineDetail = event.detail.detail;
							}
						},

						startGenerateTimer() {
							this.stopGenerateTimer();
							this.generateStartedAt = Date.now();
							this.generateElapsedSeconds = 0;
							this.generateTimer = setInterval(() => {
								this.generateElapsedSeconds = Math.floor((Date.now() - this.generateStartedAt) / 1000);
							}, 1000);
						},

						stopGenerateTimer() {
							if (this.generateTimer) clearInterval(this.generateTimer);
							this.generateTimer = null;
							this.generateStartedAt = null;
							this.generateElapsedSeconds = 0;
						},

						generateElapsedLabel() {
							const seconds = this.generateElapsedSeconds;
							const mins = Math.floor(seconds / 60);
							const secs = String(seconds % 60).padStart(2, "0");
							return mins + ":" + secs;
						},

						generateButtonText() {
							if (!this.aiBusy) return "generate";
							const status = this.generateDetail || this.generateStage || "Waiting for generated pdtt scene...";
							return this.generateElapsedLabel() + " · " + status;
						},

					}));
				});
			</script>
			<script type="module">
				import { CodeJar } from "https://cdn.jsdelivr.net/npm/codejar@4/+esm";
				const ed = document.getElementById("scene-editor");
				const hidden = document.getElementById("scene-input");
				const form = document.getElementById("render-form");
				const renderNow = () => window.htmx && window.htmx.trigger(form, "render-now");

				// Convergence guard: the output must always match the editor text.
				// hx-sync="this:replace" aborts an in-flight render when a newer one
				// fires, so the aborted request never updates the output. We track the
				// scene each request carries (sentCode) and the scene the server gave a
				// *final* answer for (settledCode: a finished render or a real scene
				// error). After every request, re-render while the editor differs from
				// settledCode — so aborted requests keep retrying until the latest text
				// renders, while a genuine scene error settles (no loop). htmx 4 event
				// names: before:request / after:request, status under detail.ctx.response.
				// after:request fires only on a real response (not on an aborted/replaced
				// request — its successor converges instead), so no retry churn.
				let sentCode = "";
				let settledCode = null;
				form.addEventListener("htmx:before:request", () => { sentCode = hidden.value; });
				form.addEventListener("htmx:after:request", (e) => {
					const status = e.detail?.ctx?.response?.status ?? 0;
					if (status === 0) return;                    // aborted/replaced or network: another request is taking over
					if (status < 500) settledCode = sentCode;    // 2xx or a real scene error is final
					if (hidden.value !== settledCode) renderNow();
				});

				// SSE replaces the old per-second status polling. The server pushes AI
				// generation progress on one long-lived stream; we route it into the
				// existing Alpine handler, gated so only the generating tab reacts.
				const events = new EventSource("/events");
				events.addEventListener("generate-status", (e) => {
					if (!window.pdttGenerateBusy || !window.pdttGenerateBusy()) return;
					try {
						window.dispatchEvent(new CustomEvent("generation-status", { detail: JSON.parse(e.data) }));
					} catch {}
				});

				const jar = CodeJar(ed, window.pdttHighlightEl, { tab: "  " });
				jar.updateCode(hidden.getAttribute("data-default") || "");
				hidden.value = jar.toString();
				jar.onUpdate((code) => { hidden.value = code; renderNow(); });
				window.pdttSetScene = (text) => { jar.updateCode(text); hidden.value = text; renderNow(); };

				// Fire the first render. htmx only attaches the form's render-now
				// listener when it processes the form, which it does on its own
				// DOMContentLoaded boot — after this deferred module runs. Triggering
				// before that dispatches into the void and the default scene never
				// renders. htmx.process(form) does the attach synchronously and is
				// idempotent, so we can trigger immediately after.
				if (window.htmx) { window.htmx.process(form); renderNow(); }
			</script>
		</head>
		<body
			class="min-h-screen bg-base-300 flex flex-col items-center p-6"
			x-data="renderPage()"
			x-on:generation-status.window="updateGenerationStatus($event)"
		>
			<div class="w-full max-w-[1800px] flex flex-col gap-6">
				<header class="grid grid-cols-1 sm:grid-cols-3 items-start gap-3">
					<div class="justify-self-start" data-copy-card>
						<pre class="hidden" data-copy-source="docs">{ llmDocs }</pre>
						<button
							type="button"
							class="btn btn-xs btn-ghost normal-case"
							onclick="pdttCopyFrom(this, 'docs')"
							title="Copy PDTT LLM docs"
						>
							LLM docs
						</button>
					</div>
					<h1 class="text-4xl font-bold text-primary text-center">pdtt playground</h1>
					<div class="justify-self-end">
						<div class="alert alert-success py-2 px-4 text-sm">
							<span>server is ready</span>
						</div>
					</div>
				</header>
				<div class="flex flex-col lg:flex-row gap-6 lg:h-[82vh]">
					<div class="lg:w-2/5 flex flex-col gap-3 min-h-0">
						<form
							id="render-form"
							hx-post="/render"
							hx-target="#output"
							hx-swap="innerHTML"
							hx-trigger="render-now delay:800ms"
							hx-sync="this:replace"
							hx-indicator="#render-form, #output"
							x-on:htmx:before:request="beforeRequest($event)"
							x-on:htmx:before:swap="beforeSwap($event)"
							x-on:htmx:after:request="afterRequest($event)"
							class="flex flex-col gap-3 flex-1 min-h-0"
						>
							<label class="label text-sm font-semibold text-base-content/80">pdtt scene</label>
							<div id="scene-editor" class="bg-base-200 border border-base-content/20 rounded-box flex-1 min-h-[55vh] lg:min-h-0 w-full" spellcheck="false"></div>
							<textarea id="scene-input" name="scene" class="hidden" data-default={ defaultScenePlaceholder }></textarea>
						</form>
						<form
							id="generate-form"
							hx-post="/generate"
							hx-target="#prompt-output"
							hx-swap="innerHTML"
							hx-indicator="#generate-form, #prompt-output"
							hx-disable="find textarea, find button"
							x-on:htmx:before:request="beforeRequest($event)"
							x-on:htmx:before:swap="beforeSwap($event)"
							x-on:htmx:after:request="afterRequest($event)"
							class="flex flex-col gap-3"
						>
							<button
								type="button"
								class="label text-sm font-semibold text-base-content/80 justify-start gap-2 p-0 w-fit cursor-pointer"
								x-on:click="freePromptOpen = !freePromptOpen"
								x-bind:aria-expanded="freePromptOpen"
							>
								<span
									class="inline-block text-xs transition-transform"
									x-bind:class="freePromptOpen ? 'rotate-90' : ''"
									aria-hidden="true"
								>
									▶
								</span>
								<span>free prompt</span>
							</button>
							<div class="flex flex-col gap-3" x-cloak x-show="freePromptOpen">
								<textarea
									name="prompt"
									class="textarea textarea-bordered bg-base-200 text-sm h-28 resize-none w-full"
									placeholder="нарисуй параболу и объясни, как меняется y = x²"
									spellcheck="true"
								></textarea>
								<button type="submit" class="btn btn-secondary w-full h-auto min-h-12 whitespace-normal normal-case" x-bind:disabled="aiBusy">
									<span
										class="loading loading-spinner loading-sm"
										x-cloak
										x-show="aiBusy"
									></span>
									<span x-text="generateButtonText()">generate</span>
								</button>
								<div id="prompt-output" class="min-h-10 text-sm text-base-content/70">
									<span class="htmx-placeholder" x-show="!aiBusy">describe a scene in natural language</span>
								</div>
							</div>
						</form>
					</div>
					<div class="lg:w-3/5 flex flex-col gap-3 min-h-0">
						<div class="flex items-center justify-between gap-3">
							<label class="label text-sm font-semibold text-base-content/80 p-0">output</label>
							<div class="text-sm" x-cloak>
								<span class="badge badge-warning gap-2 py-3" x-show="syncState() === 'compiling'">
									<span class="loading loading-spinner loading-xs"></span> compiling…
								</span>
								<span class="badge badge-error gap-1 py-3" x-show="syncState() === 'error'">✗ scene error — see output</span>
								<span class="badge badge-success gap-1 py-3" x-show="syncState() === 'synced'">✓ preview matches your scene</span>
							</div>
						</div>
						<!-- relative wrapper: #output is swapped on every render, the blur
						     overlay is a sibling so swaps never remove it. -->
						<div class="relative flex-1 min-h-[55vh] lg:min-h-0">
							<div
								id="output"
								class="absolute inset-0 bg-base-200 rounded-box border border-base-content/10 w-full overflow-auto flex flex-col"
							>
								@OutputSkeleton()
							</div>
							<div
								class="absolute inset-0 rounded-box flex items-center justify-center backdrop-blur-sm bg-base-300/60 text-center px-6"
								x-cloak
								x-show="busy || !settled"
								x-transition.opacity.duration.150ms
							>
								<div class="flex flex-col items-center gap-3">
									<span class="loading loading-spinner loading-lg text-primary"></span>
									<div>
										<div class="font-semibold text-base-content/90" x-text="pipelineTitle">Compiling your scene…</div>
										<div class="text-sm text-base-content/60" x-text="pipelineDetail"></div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
				<footer class="text-center text-xs text-base-content/30">
					<a
						href="https://t.me/contextrot"
						target="_blank"
						rel="noopener noreferrer"
						class="hover:text-base-content/50 hover:underline"
					>
						t.me/contextrot
					</a>
				</footer>
			</div>
		</body>
	</html>
}

// OutputSkeleton is the player-shaped placeholder shown before the first frame
// exists (and behind the blur overlay during it). ponytail: static chrome — no
// "result will appear here" empty state; the real player swaps in over it.
templ OutputSkeleton() {
	<div class="m-auto w-full max-w-[55vh] p-2 flex flex-col gap-2 opacity-40 animate-pulse" aria-hidden="true">
		<div class="aspect-square w-full rounded-box bg-base-300"></div>
		<div class="flex items-center gap-2">
			<div class="h-8 w-20 rounded-box bg-base-300"></div>
			<div class="h-8 flex-1 rounded-box bg-base-300"></div>
			<div class="h-8 w-16 rounded-box bg-base-300"></div>
		</div>
		<div class="h-20 w-full rounded-box bg-base-300"></div>
	</div>
}

templ RenderCompleted(id string, fps int, count int) {
	<div class="w-full flex flex-col gap-2 p-2" data-player data-id={ id } data-fps={ strconv.Itoa(fps) } data-count={ strconv.Itoa(count) }>
		<div class="relative bg-base-300 rounded-box overflow-hidden mx-auto w-full max-w-[55vh] aspect-square">
			<img data-frame-img class="absolute inset-0 h-full w-full object-contain" src={ "/dbg/" + id + "/f00000.png" } alt="frame"/>
		</div>
		<div class="flex items-center gap-2">
			<button type="button" data-play class="btn btn-sm btn-primary w-20">play</button>
			<button type="button" data-step="-1" class="btn btn-sm btn-ghost" title="previous frame">◀</button>
			<input data-scrub type="range" min="0" max={ strconv.Itoa(maxFrame(count)) } value="0" class="range range-xs range-primary flex-1"/>
			<button type="button" data-step="1" class="btn btn-sm btn-ghost" title="next frame">▶</button>
			<span data-frame-label class="font-mono text-xs tabular-nums w-24 text-right">0:00 0/{ strconv.Itoa(maxFrame(count)) }</span>
		</div>
		<div class="flex items-center justify-between gap-2">
			<a class="btn btn-xs btn-ghost" href={ "/video/" + id } download={ id + ".mp4" }>⬇ save mp4</a>
			<a data-frame-dl class="btn btn-xs btn-ghost" href={ "/dbg/" + id + "/f00000.png" } download={ id + "-f0.png" }>⬇ frame png</a>
		</div>
		<div data-vars class="text-xs overflow-auto max-h-[30vh] shrink-0 rounded-box bg-base-300 p-2 font-mono leading-relaxed">loading vars…</div>
		<script>
		(() => {
			const root = document.currentScript.closest("[data-player]");
			const id = root.dataset.id;
			const fps = parseInt(root.dataset.fps, 10) || 12;
			const count = parseInt(root.dataset.count, 10) || 1;
			const last = Math.max(0, count - 1);
			const img = root.querySelector("[data-frame-img]");
			const scrub = root.querySelector("[data-scrub]");
			const label = root.querySelector("[data-frame-label]");
			const playBtn = root.querySelector("[data-play]");
			const frameDl = root.querySelector("[data-frame-dl]");
			const varsEl = root.querySelector("[data-vars]");
			let frames = null;
			let cur = 0;
			let timer = null;

			const esc = (s) => String(s).replace(/[&<>]/g, c => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[c]));

			const openEnts = new Set();
			varsEl.addEventListener("toggle", (ev) => {
				const d = ev.target;
				if (d.tagName !== "DETAILS" || !d.dataset.ent) return;
				d.open ? openEnts.add(d.dataset.ent) : openEnts.delete(d.dataset.ent);
			}, true);

			function entDetails(e) {
				const rows = (e.fields || []).map(f =>
					`<div class="pl-4"><span class="text-primary">${esc(f.name)}</span> <span class="opacity-60">=</span> ${esc(f.value)}</div>`
				).join("");
				const open = openEnts.has(e.name) ? " open" : "";
				const dim = e.active ? "" : " opacity-50";
				return `<details data-ent="${esc(e.name)}" class="mb-1${dim}"${open}><summary class="cursor-pointer select-none"><span class="text-secondary">${esc(e.type)}</span> <b>${esc(e.name)}</b> <span class="opacity-40">${(e.fields || []).length}f</span></summary>${rows}</details>`;
			}

			function renderVars(i) {
				if (!frames) { varsEl.textContent = "(no debug data)"; return; }
				const ents = frames[i] || [];
				if (!ents.length) { varsEl.innerHTML = '<span class="opacity-50">no entities</span>'; return; }
				const active = ents.filter(e => e.active);
				const inactive = ents.filter(e => !e.active);
				let html = active.length ? active.map(entDetails).join("") : '<span class="opacity-50">no active entities</span>';
				if (inactive.length) {
					html += `<details class="mt-2"><summary class="cursor-pointer select-none text-xs uppercase opacity-50">inactive (${inactive.length})</summary>${inactive.map(entDetails).join("")}</details>`;
				}
				varsEl.innerHTML = html;
			}

			const pngURL = (i) => "/dbg/" + id + "/f" + String(i).padStart(5, "0") + ".png";

			function show(i) {
				cur = Math.min(last, Math.max(0, i));
				img.src = pngURL(cur);
				scrub.value = cur;
				const secs = Math.floor(cur / fps);
				const mmss = Math.floor(secs / 60) + ":" + String(secs % 60).padStart(2, "0");
				label.textContent = mmss + " " + cur + "/" + last;
				frameDl.href = pngURL(cur);
				frameDl.setAttribute("download", id + "-f" + cur + ".png");
				renderVars(cur);
			}

			function stop() { if (timer) { clearInterval(timer); timer = null; } playBtn.textContent = "play"; }
			function play() {
				if (timer) { stop(); return; }
				if (cur >= last) cur = -1;
				playBtn.textContent = "pause";
				timer = setInterval(() => {
					if (cur >= last) { stop(); return; }
					show(cur + 1);
				}, 1000 / fps);
			}

			playBtn.addEventListener("click", play);
			root.querySelectorAll("[data-step]").forEach(b =>
				b.addEventListener("click", () => { stop(); show(cur + parseInt(b.dataset.step, 10)); }));
			scrub.addEventListener("input", () => { stop(); show(parseInt(scrub.value, 10)); });

			fetch("/dbg/" + id + "/vars.json").then(r => r.ok ? r.json() : null).then(d => {
				frames = d && d.frames ? d.frames : null;
				show(0);
			}).catch(() => { frames = null; show(0); });
		})();
		</script>
	</div>
}

templ AdminPage(data adminPageData) {
	<!DOCTYPE html>
	<html lang="en" data-theme="dark">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>pdtt playground - admin</title>
			<link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css"/>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			<script src="https://unpkg.com/htmx.org@4.0.0-beta4/dist/htmx.min.js"></script>
			<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
		</head>
		<body class="min-h-screen bg-base-300 p-6">
			<div
				class="max-w-7xl mx-auto flex flex-col gap-6"
				data-render-version={ data.RenderVersion }
				x-data
				hx-get={ "?render_version=" + data.RenderVersion }
				hx-trigger="load delay:5s, every 5s"
				hx-target="body"
				hx-swap="outerHTML"
			>
				<header>
					<h1 class="text-3xl font-bold text-primary">pdttweb admin</h1>
					<p class="text-base-content/60 text-sm mt-1">
						auto-refreshes every 5s · { data.Now }
					</p>
					@AdminNav(data.Secret, data.Active)
				</header>
				<div>
					<h2 class="text-xl font-semibold mb-3">Renders</h2>
					<div class="overflow-x-auto rounded-box border border-base-content/10 bg-base-200">
						<table class="table table-sm">
							<thead>
								<tr>
									<th>id</th>
									<th>status</th>
									<th>stage</th>
									<th>created</th>
									<th>started</th>
									<th>done</th>
									<th>elapsed</th>
									<th>duration</th>
									<th>preview</th>
									<th>video</th>
									<th>error</th>
								</tr>
							</thead>
							<tbody>
								for _, log := range data.Logs {
									<tr>
										<td class="font-mono text-xs">{ log.ID }</td>
										<td>{ log.Status }</td>
										<td>{ log.Stage }</td>
										<td class="text-xs">{ log.CreatedAt }</td>
										<td class="text-xs">{ log.StartedAt }</td>
										<td class="text-xs">{ log.DoneAt }</td>
										<td>{ log.Elapsed }</td>
										<td>{ log.Duration }</td>
										<td class="w-44">
											if log.VideoURL != "" {
												<video class="w-40 rounded-box bg-base-300" src={ log.VideoURL } muted loop playsinline preload="metadata" controls></video>
											} else {
												<span class="text-xs text-base-content/50">—</span>
											}
										</td>
										<td class="text-xs">
											if log.VideoURL != "" {
												<a class="link" href={ log.VideoURL }>{ log.VideoSizeHuman }</a>
											} else {
												<span>{ log.VideoSizeHuman }</span>
											}
										</td>
										<td class="text-xs text-error max-w-xs truncate">{ log.Error }</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</body>
	</html>
}

templ AdminExternalPage(data adminExternalPageData) {
	<!DOCTYPE html>
	<html lang="en" data-theme="dark">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>pdtt playground - external requests</title>
			<link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css"/>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			<script src="https://unpkg.com/htmx.org@4.0.0-beta4/dist/htmx.min.js"></script>
		</head>
		<body class="min-h-screen bg-base-300 p-6">
			<div
				class="max-w-7xl mx-auto flex flex-col gap-6"
				hx-get=""
				hx-trigger="load delay:5s, every 5s"
				hx-target="body"
				hx-swap="outerHTML"
			>
				<header>
					<h1 class="text-3xl font-bold text-primary">External LLM requests</h1>
					<p class="text-base-content/60 text-sm mt-1">
						raw prompts, model replies, extracted PDTT and validation errors · { data.Now }
					</p>
					@AdminNav(data.Secret, data.Active)
				</header>
				<div class="flex flex-col gap-4">
					for _, gen := range data.Generations {
						<details class="collapse collapse-arrow bg-base-200 border border-base-content/10" open?={ gen.Status == "failed" }>
							<summary class="collapse-title">
								<div class="flex flex-wrap items-center gap-3">
									<span class="font-mono text-xs">{ gen.ID }</span>
									<span class="badge">{ gen.Status }</span>
									<span class="text-xs text-base-content/60">{ gen.Model }</span>
									<span class="text-xs">attempts: { gen.AttemptsCount }</span>
									<span class="text-xs">created: { gen.CreatedAt }</span>
									<span class="text-xs">duration: { gen.Duration }</span>
								</div>
							</summary>
							<div class="collapse-content flex flex-col gap-4">
								<div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
									<div>
										<div class="text-xs uppercase text-base-content/50 mb-1">user prompt</div>
										<pre class="bg-base-300 rounded-box p-3 text-xs whitespace-pre-wrap overflow-x-auto">{ gen.Prompt }</pre>
									</div>
									<div>
										<div class="text-xs uppercase text-base-content/50 mb-1">final error</div>
										<pre class="bg-base-300 rounded-box p-3 text-xs text-error whitespace-pre-wrap overflow-x-auto">{ gen.Error }</pre>
									</div>
									if gen.LastValidationError != "" {
										<div>
											<div class="text-xs uppercase text-base-content/50 mb-1">last validation error</div>
											<pre class="bg-base-300 rounded-box p-3 text-xs text-warning whitespace-pre-wrap overflow-x-auto">{ gen.LastValidationError }</pre>
										</div>
									}
									if gen.LastOpenRouterError != "" {
										<div>
											<div class="text-xs uppercase text-base-content/50 mb-1">last OpenRouter error</div>
											<pre class="bg-base-300 rounded-box p-3 text-xs text-error whitespace-pre-wrap overflow-x-auto">{ gen.LastOpenRouterError }</pre>
										</div>
									}
								</div>
								for _, attempt := range gen.Attempts {
									<details class="collapse collapse-arrow bg-base-300 border border-base-content/10">
										<summary class="collapse-title text-sm">
											attempt { attempt.Attempt } · { attempt.CreatedAt }
											if attempt.ValidationError != "" {
												<span class="badge badge-warning ml-2">validation failed</span>
											}
											if attempt.OpenRouterError != "" {
												<span class="badge badge-error ml-2">OpenRouter failed</span>
											}
										</summary>
										<div class="collapse-content grid grid-cols-1 xl:grid-cols-2 gap-4">
											<div>
												<div class="text-xs uppercase text-base-content/50 mb-1">request messages</div>
												<pre class="bg-base-200 rounded-box p-3 text-xs whitespace-pre-wrap overflow-x-auto">{ attempt.RequestMessages }</pre>
											</div>
											<div>
												<div class="text-xs uppercase text-base-content/50 mb-1">raw response</div>
												<pre class="bg-base-200 rounded-box p-3 text-xs whitespace-pre-wrap overflow-x-auto">{ attempt.ResponseContent }</pre>
											</div>
											<div>
												<div class="text-xs uppercase text-base-content/50 mb-1">extracted PDTT</div>
												<pre class="bg-base-200 rounded-box p-3 text-xs whitespace-pre-wrap overflow-x-auto">{ attempt.ExtractedScene }</pre>
											</div>
											<div>
												<div class="text-xs uppercase text-base-content/50 mb-1">errors</div>
												<pre class="bg-base-200 rounded-box p-3 text-xs text-error whitespace-pre-wrap overflow-x-auto">{ attempt.ValidationError }{ attempt.OpenRouterError }</pre>
											</div>
										</div>
									</details>
								}
								if gen.Scene != "" {
									<div>
										<div class="text-xs uppercase text-base-content/50 mb-1">final generated PDTT</div>
										<pre class="bg-base-300 rounded-box p-3 text-xs whitespace-pre-wrap overflow-x-auto">{ gen.Scene }</pre>
									</div>
								}
							</div>
						</details>
					}
				</div>
			</div>
		</body>
	</html>
}

templ AdminGenerationsPage(data adminGenerationsPageData) {
	<!DOCTYPE html>
	<html lang="en" data-theme="dark">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>pdtt playground - generations</title>
			<link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css"/>
			<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
			<script src="https://unpkg.com/htmx.org@4.0.0-beta4/dist/htmx.min.js"></script>
		</head>
		<body class="min-h-screen bg-base-300 p-6">
			<div
				class="max-w-7xl mx-auto flex flex-col gap-6"
				hx-get=""
				hx-trigger="load delay:5s, every 5s"
				hx-target="body"
				hx-swap="outerHTML"
			>
				<header>
					<h1 class="text-3xl font-bold text-primary">Generations</h1>
					<p class="text-base-content/60 text-sm mt-1">
						all logged AI generations · duration, text, sizes and errors · { data.Now }
					</p>
					@AdminNav(data.Secret, data.Active)
				</header>
				<div class="overflow-x-auto rounded-box border border-base-content/10 bg-base-200">
					<table class="table table-sm">
						<thead>
							<tr>
								<th>id</th>
								<th>status</th>
								<th>model</th>
								<th>created</th>
								<th>done</th>
								<th>duration</th>
								<th>attempts</th>
								<th>prompt</th>
								<th>prompt size</th>
								<th>scene</th>
								<th>scene size</th>
								<th>error</th>
							</tr>
						</thead>
						<tbody>
							for _, gen := range data.Generations {
								<tr>
									<td class="font-mono text-xs">{ gen.ID }</td>
									<td><span class="badge badge-sm">{ gen.Status }</span></td>
									<td class="text-xs max-w-48 truncate">{ gen.Model }</td>
									<td class="text-xs">{ gen.CreatedAt }</td>
									<td class="text-xs">{ gen.DoneAt }</td>
									<td>{ gen.Duration }</td>
									<td>{ gen.Attempts }</td>
									<td class="text-xs max-w-xs truncate">{ gen.PromptPreview }</td>
									<td class="text-xs">{ gen.PromptSize }</td>
									<td class="text-xs max-w-xs truncate">{ gen.ScenePreview }</td>
									<td class="text-xs">{ gen.SceneSize }</td>
									<td class="text-xs text-error max-w-xs truncate">{ gen.Error }{ gen.ValidationError }{ gen.OpenRouterError }</td>
								</tr>
								<tr>
									<td colspan="12" class="bg-base-300">
										<details class="collapse collapse-arrow">
											<summary class="collapse-title text-sm py-2 min-h-0">details</summary>
											<div class="collapse-content grid grid-cols-1 xl:grid-cols-2 gap-4">
												<div>
													<div class="text-xs uppercase text-base-content/50 mb-1">user prompt · { gen.PromptSize }</div>
													<pre class="bg-base-200 rounded-box p-3 text-xs whitespace-pre-wrap overflow-x-auto">{ gen.Prompt }</pre>
												</div>
												<div>
													<div class="text-xs uppercase text-base-content/50 mb-1">generated PDTT · { gen.SceneSize }</div>
													<pre class="bg-base-200 rounded-box p-3 text-xs whitespace-pre-wrap overflow-x-auto">{ gen.Scene }</pre>
												</div>
												if gen.Error != "" {
													<div>
														<div class="text-xs uppercase text-base-content/50 mb-1">final error</div>
														<pre class="bg-base-200 rounded-box p-3 text-xs text-error whitespace-pre-wrap overflow-x-auto">{ gen.Error }</pre>
													</div>
												}
												if gen.ValidationError != "" {
													<div>
														<div class="text-xs uppercase text-base-content/50 mb-1">last validation error</div>
														<pre class="bg-base-200 rounded-box p-3 text-xs text-warning whitespace-pre-wrap overflow-x-auto">{ gen.ValidationError }</pre>
													</div>
												}
												if gen.OpenRouterError != "" {
													<div>
														<div class="text-xs uppercase text-base-content/50 mb-1">last OpenRouter error</div>
														<pre class="bg-base-200 rounded-box p-3 text-xs text-error whitespace-pre-wrap overflow-x-auto">{ gen.OpenRouterError }</pre>
													</div>
												}
											</div>
										</details>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		</body>
	</html>
}

templ AdminNav(secret string, active string) {
	<div class="tabs tabs-boxed bg-base-200 mt-4 w-fit">
		<a class={ adminNavClass(active, "renders") } href={ "/admin/" + secret + "/renders" }>renders</a>
		<a class={ adminNavClass(active, "generations") } href={ "/admin/" + secret + "/generations" }>generations</a>
		<a class={ adminNavClass(active, "external") } href={ "/admin/" + secret + "/external" }>external LLM requests</a>
	</div>
}
