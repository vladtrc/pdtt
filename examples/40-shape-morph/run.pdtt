scene shape_morph

square s:
  at: [0, 0]
  side: 2
  angle: -3 * math.tau / 8
  stroke: color.white

dot d:
  at: [0, 0]
  radius: 1
  stroke: color.white
  fill: color.pink @ 50%

| 1s | s{draw: 0} -> s        # s is born, drawn along its contour (self-transition)
| 1s | morph | s -> d         # s morphs into d (structural)
| 1s | d.opacity -> 0          # d fades out
