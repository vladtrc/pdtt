scene change_camera

tex nabla:
  text: "\\nabla\\textbf{u}"
  scale: 3
  at: left(2.5)

square sq:
  side: 2
  at: right_of(nabla, 3)

home = frame

| 2s | smooth
| frame.w -> nabla.w * 1.2
| frame.at -> nabla.at

| 1s

| 1.5s | smooth
| frame -> home

| 2s | smooth
| frame.h -> sq.w * 1.2
| frame.at -> sq.at

| 1s

| 1.5s | smooth | frame -> home
