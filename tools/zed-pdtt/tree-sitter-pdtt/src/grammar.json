{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "pdtt",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "line"
          },
          {
            "type": "SYMBOL",
            "name": "blank_line"
          }
        ]
      }
    },
    "blank_line": {
      "type": "STRING",
      "value": "\n"
    },
    "line": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_item"
          }
        },
        {
          "type": "STRING",
          "value": "\n"
        }
      ]
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "duration"
        },
        {
          "type": "SYMBOL",
          "name": "percent"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "constant"
        },
        {
          "type": "SYMBOL",
          "name": "modifier"
        },
        {
          "type": "SYMBOL",
          "name": "keyword"
        },
        {
          "type": "SYMBOL",
          "name": "arrow"
        },
        {
          "type": "SYMBOL",
          "name": "bar"
        },
        {
          "type": "SYMBOL",
          "name": "open_bracket"
        },
        {
          "type": "SYMBOL",
          "name": "close_bracket"
        },
        {
          "type": "SYMBOL",
          "name": "delimiter"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "#[^\\n]*"
      }
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^\"\\\\\\n]"
                },
                {
                  "type": "PATTERN",
                  "value": "\\\\."
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "duration": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "(?:\\d+(?:\\.\\d+)?|\\.\\d+)s"
      }
    },
    "percent": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "(?:\\d+(?:\\.\\d+)?|\\.\\d+)%"
      }
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "(?:\\d+(?:\\.\\d+)?|\\.\\d+)"
      }
    },
    "constant": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "(?:color|corner|approx|math)\\.[A-Za-z_][A-Za-z0-9_]*"
      }
    },
    "modifier": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "ease:[A-Za-z_][A-Za-z0-9_]*"
          },
          {
            "type": "PATTERN",
            "value": "transition:[A-Za-z_][A-Za-z0-9_]*"
          },
          {
            "type": "PATTERN",
            "value": "in:[A-Za-z_][A-Za-z0-9_]*"
          },
          {
            "type": "PATTERN",
            "value": "ou:[A-Za-z_][A-Za-z0-9_]*"
          },
          {
            "type": "PATTERN",
            "value": "highlight:[A-Za-z_][A-Za-z0-9_]*"
          },
          {
            "type": "PATTERN",
            "value": "after"
          },
          {
            "type": "PATTERN",
            "value": "lag"
          },
          {
            "type": "PATTERN",
            "value": "stagger"
          },
          {
            "type": "PATTERN",
            "value": "by"
          }
        ]
      }
    },
    "keyword": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "scene"
          },
          {
            "type": "STRING",
            "value": "run"
          },
          {
            "type": "STRING",
            "value": "extern"
          },
          {
            "type": "STRING",
            "value": "fn"
          },
          {
            "type": "STRING",
            "value": "rate"
          },
          {
            "type": "STRING",
            "value": "for"
          },
          {
            "type": "STRING",
            "value": "each"
          },
          {
            "type": "STRING",
            "value": "as"
          },
          {
            "type": "STRING",
            "value": "snapshot"
          },
          {
            "type": "STRING",
            "value": "from"
          },
          {
            "type": "STRING",
            "value": "range"
          },
          {
            "type": "STRING",
            "value": "self"
          },
          {
            "type": "STRING",
            "value": "it"
          },
          {
            "type": "STRING",
            "value": "frame"
          }
        ]
      }
    },
    "arrow": {
      "type": "STRING",
      "value": "->"
    },
    "bar": {
      "type": "STRING",
      "value": "|"
    },
    "open_bracket": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "["
          },
          {
            "type": "STRING",
            "value": "("
          },
          {
            "type": "STRING",
            "value": "{"
          }
        ]
      }
    },
    "close_bracket": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "]"
          },
          {
            "type": "STRING",
            "value": ")"
          },
          {
            "type": "STRING",
            "value": "}"
          }
        ]
      }
    },
    "delimiter": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": ","
          },
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "STRING",
            "value": "."
          }
        ]
      }
    },
    "operator": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "=="
          },
          {
            "type": "STRING",
            "value": "!="
          },
          {
            "type": "STRING",
            "value": "<="
          },
          {
            "type": "STRING",
            "value": ">="
          },
          {
            "type": "STRING",
            "value": "="
          },
          {
            "type": "STRING",
            "value": "@"
          },
          {
            "type": "STRING",
            "value": "?"
          },
          {
            "type": "STRING",
            "value": "+"
          },
          {
            "type": "STRING",
            "value": "-"
          },
          {
            "type": "STRING",
            "value": "*"
          },
          {
            "type": "STRING",
            "value": "/"
          },
          {
            "type": "STRING",
            "value": "%"
          },
          {
            "type": "STRING",
            "value": "<"
          },
          {
            "type": "STRING",
            "value": ">"
          }
        ]
      }
    },
    "identifier": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[A-Za-z_][A-Za-z0-9_]*"
      }
    },
    "text": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^ \\t\\r\\f\\n|\\[\\](){}\",#:+=*\\/%@?<>.!-]+"
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r\\f]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}